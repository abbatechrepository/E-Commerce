# Environment / secrets
.env
.env.*
!.env.example
auth.json

# Dependencies
/vendor/
/node_modules/

# Build artifacts
/public/build/
/public/hot
/public/storage

# Laravel runtime cache / logs
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

/storage/*.key
/storage/logs/*
!/storage/logs/.gitignore

/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore

# Generated demo assets
/storage/app/public/products/demo/*

# PHPUnit / test cache
/.phpunit.cache
/.phpunit.result.cache

# Optional local DB files
/database/*.sqlite
/database/*.sqlite-journal

# JS package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local tools / IDE
/.fleet/
/.idea/
/.vscode/

# OS files
.DS_Store
Thumbs.db

# Legacy / local VM tooling
Homestead.json
Homestead.yaml
